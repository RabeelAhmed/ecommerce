<%# partials/skeleton-card.ejs — loading placeholder for product cards %>
<div class="group relative bg-white rounded-2xl overflow-hidden border border-stone-100 shadow-sm animate-pulse" aria-hidden="true" aria-label="Loading product...">

  <!-- Image placeholder -->
  <div class="aspect-square w-full bg-stone-200"></div>

  <!-- Content placeholder -->
  <div class="p-4 space-y-3">
    <!-- Category tag -->
    <div class="h-4 w-20 bg-stone-200 rounded-full"></div>

    <!-- Product name -->
    <div class="space-y-1.5">
      <div class="h-5 w-4/5 bg-stone-200 rounded-lg"></div>
      <div class="h-5 w-3/5 bg-stone-200 rounded-lg"></div>
    </div>

    <!-- Price + button row -->
    <div class="flex items-center justify-between pt-2">
      <div class="h-6 w-16 bg-stone-200 rounded-lg"></div>
      <div class="h-9 w-24 bg-stone-200 rounded-full"></div>
    </div>
  </div>

</div>
