<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-stone-100 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex-shrink-0 group" id="nav-logo">
        <span class="font-display text-2xl font-bold text-brand-500 tracking-wide group-hover:text-brand-600 transition-colors duration-200">
          NOMADICA
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
        <a href="/"      class="nav-link text-sm pb-1" id="nav-home">Home</a>
        <a href="/shop"  class="nav-link text-sm pb-1" id="nav-shop">Shop</a>
        <% if (locals.user && locals.user.role === 'admin') { %>
          <a href="/admin" class="nav-link text-sm pb-1 text-emerald-600 hover:text-emerald-700 font-semibold" id="nav-admin">Admin</a>
        <% } %>
        <a href="/account" class="nav-link text-sm pb-1" id="nav-account">Account</a>

        <!-- Cart -->
        <a href="/cart" class="relative flex items-center gap-1.5 text-sm font-medium text-stone-700 hover:text-brand-600 transition-colors duration-200" id="nav-cart">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-1.5 6h11M10 19a1 1 0 100 2 1 1 0 000-2zm7 0a1 1 0 100 2 1 1 0 000-2z" />
          </svg>
          Cart
          <span id="cart-badge" class="absolute -top-2 -right-3 bg-brand-500 text-white text-[10px] font-bold w-4 h-4 rounded-full flex items-center justify-center leading-none <%= locals.cartItemCount > 0 ? '' : 'hidden' %>">
            <%= locals.cartItemCount || 0 %>
          </span>
        </a>
      </nav>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-stone-600 hover:text-brand-600 hover:bg-brand-50 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-brand-400"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <!-- Hamburger icon -->
        <svg id="icon-hamburger" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <!-- Close icon -->
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-stone-100 bg-white"
  >
    <nav class="flex flex-col px-4 py-4 gap-1" aria-label="Mobile navigation">
      <a href="/"        class="px-3 py-2 rounded-lg text-stone-700 font-medium hover:bg-brand-50 hover:text-brand-600 transition-colors" id="mob-nav-home">Home</a>
      <a href="/shop"    class="px-3 py-2 rounded-lg text-stone-700 font-medium hover:bg-brand-50 hover:text-brand-600 transition-colors" id="mob-nav-shop">Shop</a>
      <% if (locals.user && locals.user.role === 'admin') { %>
        <a href="/admin" class="px-3 py-2 rounded-lg text-emerald-600 font-semibold hover:bg-emerald-50 transition-colors" id="mob-nav-admin">Admin Dashboard</a>
      <% } %>
      <a href="/account" class="px-3 py-2 rounded-lg text-stone-700 font-medium hover:bg-brand-50 hover:text-brand-600 transition-colors" id="mob-nav-account">Account</a>
      <a href="/cart"    class="px-3 py-2 rounded-lg text-stone-700 font-medium hover:bg-brand-50 hover:text-brand-600 transition-colors flex items-center gap-2" id="mob-nav-cart">
        Cart
        <span class="bg-brand-500 text-white text-[10px] font-bold w-4 h-4 rounded-full flex items-center justify-center <%= locals.cartItemCount > 0 ? '' : 'hidden' %>"><%= locals.cartItemCount || 0 %></span>
      </a>
    </nav>
  </div>
</header>

<script>
  (function () {
    const btn  = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const ham  = document.getElementById('icon-hamburger');
    const cls  = document.getElementById('icon-close');

    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', isOpen);
      ham.classList.toggle('hidden', !isOpen);
      cls.classList.toggle('hidden', isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  })();
</script>
