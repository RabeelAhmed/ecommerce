<%# views/pages/product.ejs — single product detail page %>

<!-- ─── Breadcrumb ──────────────────────────────────────────────────────────── -->
<div class="bg-stone-50 border-b border-stone-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <nav class="flex items-center gap-2 text-xs text-stone-400" aria-label="Breadcrumb">
      <a href="/" class="hover:text-brand-500 transition-colors">Home</a>
      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
      </svg>
      <a href="/shop" class="hover:text-brand-500 transition-colors">Shop</a>
      <% if (product.category_slug) { %>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a href="/shop?category=<%= product.category_slug %>"
           class="hover:text-brand-500 transition-colors capitalize">
          <%= product.category_name %>
        </a>
      <% } %>
      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
      </svg>
      <span class="text-stone-600 font-medium line-clamp-1"><%= product.name %></span>
    </nav>
  </div>
</div>

<!-- ─── Main Product Section ────────────────────────────────────────────────── -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16" id="product-detail">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 xl:gap-20 items-start">

    <!-- ─── Product Image ─────────────────────────────────────────────────────── -->
    <div class="space-y-4">
      <div class="relative overflow-hidden rounded-3xl bg-brand-50 aspect-square shadow-lg group">
        <% if (product.image_url) { %>
          <img
            src="<%= product.image_url %>"
            alt="<%= product.name %>"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          >
        <% } else { %>
          <!-- Placeholder when no image -->
          <div class="w-full h-full flex flex-col items-center justify-center gap-4">
            <svg class="w-20 h-20 text-brand-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <p class="text-brand-300 text-sm font-medium">No image available</p>
          </div>
        <% } %>

        <!-- Out of stock overlay -->
        <% if (product.stock === 0) { %>
          <div class="absolute inset-0 bg-black/50 flex items-center justify-center rounded-3xl">
            <span class="bg-white text-stone-700 font-bold text-sm px-6 py-2 rounded-full uppercase tracking-widest shadow-lg">
              Sold Out
            </span>
          </div>
        <% } %>

        <!-- Category badge -->
        <% if (product.category_name) { %>
          <span class="absolute top-4 left-4 bg-white/90 backdrop-blur-sm text-stone-700 text-xs font-semibold px-3 py-1.5 rounded-full shadow-sm capitalize">
            <%= product.category_name %>
          </span>
        <% } %>
      </div>

      <!-- Trust badges under image -->
      <div class="grid grid-cols-3 gap-3 pt-2">
        <div class="flex flex-col items-center gap-1.5 p-3 bg-stone-50 rounded-2xl text-center">
          <svg class="w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
          <p class="text-[11px] font-semibold text-stone-600 leading-tight">Ethically<br>Sourced</p>
        </div>
        <div class="flex flex-col items-center gap-1.5 p-3 bg-stone-50 rounded-2xl text-center">
          <svg class="w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/>
          </svg>
          <p class="text-[11px] font-semibold text-stone-600 leading-tight">Worldwide<br>Shipping</p>
        </div>
        <div class="flex flex-col items-center gap-1.5 p-3 bg-stone-50 rounded-2xl text-center">
          <svg class="w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M3 14h18M10 6l-4 4 4 4M14 6l4 4-4 4"/>
          </svg>
          <p class="text-[11px] font-semibold text-stone-600 leading-tight">Free<br>Returns</p>
        </div>
      </div>
    </div>

    <!-- ─── Product Info ───────────────────────────────────────────────────────── -->
    <div class="py-2 space-y-8">

      <!-- Category + Name -->
      <div class="space-y-3">
        <% if (product.category_name) { %>
          <p class="text-xs font-semibold tracking-[0.2em] uppercase text-brand-500">
            <%= product.category_name %>
          </p>
        <% } %>
        <h1 class="font-display text-4xl sm:text-5xl font-bold text-stone-900 leading-tight">
          <%= product.name %>
        </h1>
      </div>

      <!-- Price + Stock status -->
      <div class="flex items-center gap-5">
        <span class="font-display text-4xl font-bold text-brand-600">
          $<%= Number(product.price).toFixed(2) %>
        </span>

        <% if (product.stock > 0) { %>
          <span class="inline-flex items-center gap-1.5 text-sm font-medium text-emerald-700 bg-emerald-50 border border-emerald-200 px-3 py-1.5 rounded-full">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 8 8">
              <circle cx="4" cy="4" r="4"/>
            </svg>
            <%= product.stock <= 5 ? 'Only ' + product.stock + ' left' : 'In Stock' %>
          </span>
        <% } else { %>
          <span class="inline-flex items-center gap-1.5 text-sm font-medium text-red-600 bg-red-50 border border-red-200 px-3 py-1.5 rounded-full">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 8 8">
              <circle cx="4" cy="4" r="4"/>
            </svg>
            Out of Stock
          </span>
        <% } %>
      </div>

      <!-- Divider -->
      <hr class="border-stone-100">

      <!-- Description -->
      <% if (product.description) { %>
        <div class="space-y-2">
          <h2 class="text-xs font-semibold tracking-[0.15em] uppercase text-stone-400">About this piece</h2>
          <p class="text-stone-600 leading-relaxed text-base"><%= product.description %></p>
        </div>
      <% } %>

      <!-- ─── Add to Cart ─────────────────────────────────────────────────────── -->
      <% if (product.stock > 0) { %>
        <form id="add-to-cart-form" class="space-y-4" data-product-id="<%= product.id %>">

          <!-- Quantity Selector -->
          <div class="space-y-2">
            <label for="qty-input" class="text-xs font-semibold tracking-[0.15em] uppercase text-stone-400">
              Quantity
            </label>
            <div class="flex items-center gap-3">
              <div class="inline-flex items-center border border-stone-200 rounded-xl overflow-hidden shadow-sm">
                <button
                  type="button"
                  id="qty-decrease"
                  aria-label="Decrease quantity"
                  class="w-11 h-11 flex items-center justify-center text-stone-600 hover:bg-brand-50 hover:text-brand-600
                         transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-brand-400"
                >
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4"/>
                  </svg>
                </button>

                <input
                  type="number"
                  id="qty-input"
                  name="quantity"
                  value="1"
                  min="1"
                  max="<%= product.stock %>"
                  class="w-14 h-11 text-center text-base font-semibold text-stone-800 bg-white border-x border-stone-200
                         focus:outline-none focus:ring-2 focus:ring-inset focus:ring-brand-400 [appearance:textfield]
                         [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none"
                  aria-label="Quantity"
                >

                <button
                  type="button"
                  id="qty-increase"
                  aria-label="Increase quantity"
                  class="w-11 h-11 flex items-center justify-center text-stone-600 hover:bg-brand-50 hover:text-brand-600
                         transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-brand-400"
                >
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
                  </svg>
                </button>
              </div>
              <span class="text-xs text-stone-400"><%= product.stock %> available</span>
            </div>
          </div>

          <!-- Add to Cart Button -->
          <div class="flex flex-col sm:flex-row gap-3 pt-2">
            <button
              type="submit"
              id="add-to-cart-btn"
              class="btn-primary flex-1 flex items-center justify-center gap-2 !py-4 !text-base !px-8 shadow-lg shadow-brand-200/50 hover:shadow-brand-200"
              data-product-slug="<%= product.slug %>"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-1.5 6h11M10 19a1 1 0 100 2 1 1 0 000-2zm7 0a1 1 0 100 2 1 1 0 000-2z"/>
              </svg>
              Add to Cart
            </button>

            <button
              type="button"
              id="wishlist-btn"
              aria-label="Save to wishlist"
              class="btn-outline !py-4 !px-5 flex items-center justify-center"
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
              </svg>
            </button>
          </div>

        </form>

      <% } else { %>
        <!-- Out of stock CTA -->
        <div class="space-y-3">
          <button
            disabled
            class="w-full flex items-center justify-center gap-2 py-4 px-8 rounded-full font-semibold text-base
                   bg-stone-100 text-stone-400 cursor-not-allowed border border-stone-200"
            aria-label="This product is out of stock"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-1.5 6h11M10 19a1 1 0 100 2 1 1 0 000-2zm7 0a1 1 0 100 2 1 1 0 000-2z"/>
            </svg>
            Sold Out
          </button>
          <p class="text-center text-xs text-stone-400">
            This item is currently unavailable. Check back soon.
          </p>
        </div>
      <% } %>

      <!-- Back to Shop link -->
      <div class="pt-4">
        <a href="/shop<%= product.category_slug ? '?category=' + product.category_slug : '' %>"
           class="inline-flex items-center gap-2 text-sm font-medium text-stone-500 hover:text-brand-600 transition-colors group"
           id="back-to-shop">
          <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1 duration-200"
               fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
          </svg>
          Back to <%= product.category_name ? product.category_name : 'Shop' %>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ─── Quantity Selector Script ─────────────────────────────────────────────── -->
<script>
  (function () {
    const input    = document.getElementById('qty-input');
    const increase = document.getElementById('qty-increase');
    const decrease = document.getElementById('qty-decrease');

    if (!input || !increase || !decrease) return;

    const max = parseInt(input.getAttribute('max'), 10);
    const min = parseInt(input.getAttribute('min'), 10);

    function clamp(v) { return Math.min(Math.max(v, min), max); }
    function refresh() {
      const v = clamp(parseInt(input.value, 10) || min);
      input.value          = v;
      decrease.disabled    = (v <= min);
      increase.disabled    = (v >= max);
      decrease.classList.toggle('opacity-40', v <= min);
      increase.classList.toggle('opacity-40', v >= max);
    }

    increase.addEventListener('click', () => { input.value = clamp((parseInt(input.value, 10) || min) + 1); refresh(); });
    decrease.addEventListener('click', () => { input.value = clamp((parseInt(input.value, 10) || min) - 1); refresh(); });
    input.addEventListener('input', refresh);
    refresh();
  })();
</script>
