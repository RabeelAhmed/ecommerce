<section class="min-h-[80vh] flex flex-col items-center justify-center text-center px-4 py-20">

  <!-- Illustration -->
  <div class="relative mb-10 select-none">
    <svg width="260" height="200" viewBox="0 0 260 200" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <!-- Ground -->
      <ellipse cx="130" cy="185" rx="100" ry="10" fill="#e7e5e4" opacity="0.6"/>

      <!-- Map / scroll -->
      <rect x="60" y="90" width="140" height="90" rx="8" fill="#fdf6e3" stroke="#d6c9a4" stroke-width="2"/>
      <!-- Map lines -->
      <line x1="80" y1="115" x2="180" y2="115" stroke="#c9b99a" stroke-width="2" stroke-linecap="round"/>
      <line x1="80" y1="130" x2="155" y2="130" stroke="#c9b99a" stroke-width="2" stroke-linecap="round"/>
      <line x1="80" y1="145" x2="165" y2="145" stroke="#c9b99a" stroke-width="2" stroke-linecap="round"/>
      <!-- Map X mark -->
      <circle cx="155" cy="148" r="10" fill="#f59e0b" opacity="0.3"/>
      <line x1="149" y1="142" x2="161" y2="154" stroke="#b45309" stroke-width="2" stroke-linecap="round"/>
      <line x1="161" y1="142" x2="149" y2="154" stroke="#b45309" stroke-width="2" stroke-linecap="round"/>

      <!-- Person body -->
      <rect x="108" y="120" width="18" height="30" rx="4" fill="#78716c"/>
      <!-- Person head -->
      <circle cx="117" cy="112" r="10" fill="#fbbf60"/>
      <!-- Hat -->
      <rect x="107" y="104" width="20" height="5" rx="2" fill="#44403c"/>
      <rect x="110" y="96" width="14" height="10" rx="3" fill="#57534e"/>
      <!-- Arms -->
      <line x1="108" y1="128" x2="92" y2="138" stroke="#78716c" stroke-width="4" stroke-linecap="round"/>
      <line x1="126" y1="128" x2="140" y2="122" stroke="#78716c" stroke-width="4" stroke-linecap="round"/>
      <!-- Legs -->
      <line x1="112" y1="150" x2="108" y2="168" stroke="#78716c" stroke-width="4" stroke-linecap="round"/>
      <line x1="122" y1="150" x2="126" y2="168" stroke="#78716c" stroke-width="4" stroke-linecap="round"/>
      <!-- Walking stick -->
      <line x1="140" y1="122" x2="150" y2="165" stroke="#a8a29e" stroke-width="3" stroke-linecap="round"/>

      <!-- Stars / floating dots -->
      <circle cx="40" cy="50" r="3" fill="#f59e0b" opacity="0.7"/>
      <circle cx="220" cy="40" r="2" fill="#a78bfa" opacity="0.8"/>
      <circle cx="55" cy="150" r="2" fill="#6ee7b7" opacity="0.7"/>
      <circle cx="210" cy="130" r="3" fill="#fb923c" opacity="0.6"/>

      <!-- Question marks floating -->
      <text x="30" y="80" font-size="22" fill="#d6d3d1" font-family="serif" font-weight="bold">?</text>
      <text x="215" y="75" font-size="18" fill="#d6d3d1" font-family="serif" font-weight="bold">?</text>
    </svg>

    <!-- 404 badge -->
    <div class="absolute -top-4 -right-4 w-16 h-16 rounded-full bg-brand-500 shadow-lg flex items-center justify-center">
      <span class="text-white font-display font-bold text-lg leading-none">404</span>
    </div>
  </div>

  <!-- Copy -->
  <h1 class="font-display text-4xl sm:text-5xl font-bold text-stone-900 mb-4">
    Lost on the trail?
  </h1>
  <p class="text-stone-500 text-lg max-w-md mx-auto mb-10 leading-relaxed">
    The page you're looking for has wandered off. It might have been moved,
    deleted, or perhaps it never existed at all.
  </p>

  <!-- Actions -->
  <div class="flex flex-col sm:flex-row gap-4 items-center justify-center">
    <a
      href="/shop"
      id="btn-404-shop"
      class="inline-flex items-center gap-2 px-7 py-3.5 bg-brand-600 hover:bg-brand-700 text-white font-semibold rounded-xl shadow-md hover:shadow-lg transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-brand-400 focus:ring-offset-2"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
      </svg>
      Browse the Shop
    </a>
    <a
      href="/"
      id="btn-404-home"
      class="inline-flex items-center gap-2 px-7 py-3.5 border border-stone-200 text-stone-700 hover:bg-stone-50 font-semibold rounded-xl transition-all duration-200"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
      Go Home
    </a>
  </div>

</section>
