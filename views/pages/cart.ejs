<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-display font-bold text-stone-900 mb-8">Your Cart</h1>

    <% if (!locals.cart || !locals.cart.items || locals.cart.items.length === 0) { %>
        <!-- ─── Rich Empty Cart State ───────────────────────────────────────── -->
        <div class="flex flex-col items-center justify-center py-24 text-center">

          <!-- Hand-drawn style empty bag illustration -->
          <div class="relative mb-10 select-none">
            <svg width="240" height="220" viewBox="0 0 240 220" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <!-- Ground shadow -->
              <ellipse cx="120" cy="208" rx="85" ry="8" fill="#e7e5e4" opacity="0.5"/>

              <!-- Tote bag body -->
              <path d="M55 90 Q50 155 60 185 Q72 205 120 205 Q168 205 180 185 Q190 155 185 90 Z"
                    fill="#fdf6e3" stroke="#c9b99a" stroke-width="2.5" stroke-linejoin="round"/>

              <!-- Bag top rim -->
              <rect x="52" y="82" width="136" height="16" rx="8" fill="#e8dfc8" stroke="#c9b99a" stroke-width="2"/>

              <!-- Bag handles -->
              <path d="M85 82 Q80 50 95 42 Q110 35 120 40 Q130 35 145 42 Q160 50 155 82"
                    fill="none" stroke="#c9b99a" stroke-width="3" stroke-linecap="round"/>

              <!-- Inner empty lines (bag texture) -->
              <line x1="95" y1="115" x2="145" y2="115" stroke="#e2d9c5" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="90" y1="135" x2="150" y2="135" stroke="#e2d9c5" stroke-width="1.5" stroke-linecap="round"/>
              <line x1="88" y1="155" x2="152" y2="155" stroke="#e2d9c5" stroke-width="1.5" stroke-linecap="round"/>

              <!-- Floating sad items outside the bag -->
              <!-- Star / tag -->
              <g transform="translate(22, 55) rotate(-15)">
                <rect width="28" height="20" rx="4" fill="#fde68a" stroke="#f59e0b" stroke-width="1.5"/>
                <line x1="6" y1="6" x2="22" y2="6" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="6" y1="12" x2="18" y2="12" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="24" cy="5" r="2" fill="#f59e0b"/>
              </g>
              <!-- Small box -->
              <g transform="translate(188, 60) rotate(12)">
                <rect width="26" height="22" rx="3" fill="#bfdbfe" stroke="#60a5fa" stroke-width="1.5"/>
                <line x1="13" y1="0" x2="13" y2="22" stroke="#60a5fa" stroke-width="1" stroke-linecap="round"/>
                <line x1="0" y1="11" x2="26" y2="11" stroke="#60a5fa" stroke-width="1" stroke-linecap="round"/>
              </g>
              <!-- Heart -->
              <path d="M35 140 Q35 134 42 134 Q48 134 48 140 Q48 134 55 134 Q62 134 62 140 Q62 147 48 155 Q35 147 35 140Z"
                    fill="#fca5a5" opacity="0.8"/>
              <!-- Sparkles -->
              <circle cx="175" cy="130" r="3" fill="#a78bfa" opacity="0.7"/>
              <circle cx="30" cy="175" r="2.5" fill="#6ee7b7" opacity="0.7"/>
              <circle cx="195" cy="165" r="2" fill="#f59e0b" opacity="0.6"/>

              <!-- Question mark in bag -->
              <text x="103" y="145" font-size="30" fill="#d6cdb8" font-family="serif" font-weight="bold" opacity="0.6">?</text>
            </svg>
          </div>

          <!-- Copy -->
          <h2 class="font-display text-3xl font-bold text-stone-900 mb-3">Your bag is empty</h2>
          <p class="text-stone-500 max-w-xs mx-auto mb-8 leading-relaxed">
            You haven&rsquo;t added any treasures yet. Explore our handcrafted collection and find something you love.
          </p>

          <!-- CTA -->
          <a
            href="/shop"
            id="empty-cart-shop-btn"
            class="inline-flex items-center gap-2 px-8 py-3.5 bg-brand-600 hover:bg-brand-700 text-white font-semibold rounded-xl shadow-md hover:shadow-lg transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-brand-400 focus:ring-offset-2"
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
            </svg>
            Start Shopping
          </a>
        </div>
    <% } else { %>
        <div class="flex flex-col lg:flex-row gap-8">
            <!-- Cart Items -->
            <div class="lg:w-2/3">
                <div class="bg-white rounded-2xl border border-stone-100 shadow-sm overflow-hidden">
                    <ul role="list" class="divide-y divide-stone-100" id="cart-item-list">
                        <% cart.items.forEach(item => { %>
                            <li class="p-6 flex flex-col sm:flex-row gap-6 cart-item" data-product-id="<%= item.productId %>" data-stock="<%= item.stock %>">
                                <!-- Image -->
                                <div class="w-full sm:w-24 h-24 flex-shrink-0 bg-stone-50 rounded-lg overflow-hidden relative border border-stone-100">
                                    <% if (item.imageUrl) { %>
                                        <img src="<%= item.imageUrl %>" alt="<%= item.name %>" class="w-full h-full object-cover object-center">
                                    <% } else { %>
                                        <div class="w-full h-full flex items-center justify-center text-stone-300">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                            </svg>
                                        </div>
                                    <% } %>
                                </div>

                                <!-- Details -->
                                <div class="flex-1 flex flex-col">
                                    <div class="flex justify-between items-start mb-2">
                                        <div>
                                            <h3 class="text-lg font-medium text-stone-900">
                                                <a href="/shop/<%= item.slug %>" class="hover:text-brand-600 transition-colors"><%= item.name %></a>
                                            </h3>
                                            <p class="mt-1 text-sm text-stone-500">Price: $<%= parseFloat(item.price).toFixed(2) %></p>
                                        </div>
                                        <p class="text-lg font-medium text-stone-900 item-subtotal" data-price="<%= item.price %>">
                                            $<%= (parseFloat(item.price) * item.quantity).toFixed(2) %>
                                        </p>
                                    </div>

                                    <div class="flex items-end justify-between flex-1 mt-4">
                                        <div class="flex items-center border border-stone-200 rounded-lg bg-stone-50 overflow-hidden">
                                            <button type="button" class="px-3 py-1.5 text-stone-500 hover:text-brand-600 hover:bg-stone-100 transition-colors btn-decrease">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                                                </svg>
                                            </button>
                                            <input type="number" min="1" max="<%= item.stock %>" value="<%= item.quantity %>" class="w-12 text-center bg-transparent text-sm font-medium text-stone-900 focus:outline-none focus:ring-0 border-none p-0 quantity-input">
                                            <button type="button" class="px-3 py-1.5 text-stone-500 hover:text-brand-600 hover:bg-stone-100 transition-colors btn-increase">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                                                </svg>
                                            </button>
                                        </div>
                                        
                                        <button type="button" class="text-sm font-medium text-red-500 hover:text-red-600 transition-colors flex items-center gap-1 btn-remove">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                            </svg>
                                            Remove
                                        </button>
                                    </div>
                                </div>
                            </li>
                        <% }) %>
                    </ul>
                </div>
            </div>

            <!-- Order Summary -->
            <div class="lg:w-1/3">
                <div class="bg-stone-50 rounded-2xl p-6 border border-stone-100 shadow-sm sticky top-24">
                    <h2 class="text-lg font-medium text-stone-900 mb-6">Order Summary</h2>
                    
                    <div class="flow-root">
                        <dl class="-my-4 text-sm divide-y divide-stone-200">
                            <div class="py-4 flex items-center justify-between">
                                <dt class="text-stone-600">Subtotal</dt>
                                <dd class="font-medium text-stone-900" id="summary-subtotal">$<%= cart.total %></dd>
                            </div>
                            <div class="py-4 flex items-center justify-between">
                                <dt class="text-stone-600">Shipping</dt>
                                <dd class="font-medium text-stone-900">Calculated at checkout</dd>
                            </div>
                            <div class="py-4 flex items-center justify-between">
                                <dt class="text-base font-medium text-stone-900">Total</dt>
                                <dd class="text-base font-bold text-brand-600" id="summary-total">$<%= cart.total %></dd>
                            </div>
                        </dl>
                    </div>

                    <div class="mt-8">
                        <a href="/checkout" class="w-full flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-lg text-white bg-brand-600 hover:bg-brand-700 shadow-sm transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500">
                            Proceed to Checkout
                        </a>
                    </div>
                </div>
            </div>
        </div>
    <% } %>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const cartList = document.getElementById('cart-item-list');
    if (!cartList) return;

    cartList.addEventListener('click', async (e) => {
        const btnDecrease = e.target.closest('.btn-decrease');
        const btnIncrease = e.target.closest('.btn-increase');
        const btnRemove = e.target.closest('.btn-remove');
        
        if (btnDecrease || btnIncrease) {
            const itemEl = e.target.closest('.cart-item');
            const input = itemEl.querySelector('.quantity-input');
            let qty = parseInt(input.value, 10);
            
            if (btnDecrease && qty > 1) qty--;
            else if (btnIncrease && qty < parseInt(itemEl.dataset.stock, 10)) qty++;
            else return; // Reached limit

            input.value = qty;
            await updateItem(itemEl.dataset.productId, qty);
        } else if (btnRemove) {
            const itemEl = e.target.closest('.cart-item');
            await removeItem(itemEl.dataset.productId);
        }
    });

    cartList.addEventListener('change', async (e) => {
        if (e.target.classList.contains('quantity-input')) {
            const itemEl = e.target.closest('.cart-item');
            let qty = parseInt(e.target.value, 10);
            const stock = parseInt(itemEl.dataset.stock, 10);
            
            if (isNaN(qty) || qty < 1) qty = 1;
            if (qty > stock) qty = stock;
            
            e.target.value = qty;
            await updateItem(itemEl.dataset.productId, qty);
        }
    });

    async function updateItem(productId, quantity) {
        try {
            const res = await fetch(`/api/cart/items/${productId}`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                    'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
                },
                body: JSON.stringify({ quantity })
            });
            const data = await res.json();
            if (res.ok) {
                window.location.reload();
            } else {
                showToast(data.message || 'Failed to update item', 'error');
            }
        } catch (err) {
            console.error(err);
            showToast('An error occurred while updating the cart.', 'error');
        }
    }

    async function removeItem(productId) {
        try {
            const res = await fetch(`/api/cart/items/${productId}`, {
                method: 'DELETE',
                headers: {
                    'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
                }
            });
            const data = await res.json();
            if (res.ok) {
                window.location.reload();
            } else {
                showToast(data.message || 'Failed to remove item', 'error');
            }
        } catch (err) {
            console.error(err);
            showToast('An error occurred while removing the item.', 'error');
        }
    }
});
</script>
