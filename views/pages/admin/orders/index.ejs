<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8">
  <div>
    <h1 class="text-3xl font-serif text-stone-900 tracking-tight">Orders</h1>
    <p class="text-stone-500 mt-1">View and manage customer orders.</p>
  </div>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-stone-100 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-stone-50 border-b border-stone-100 text-stone-500 text-sm uppercase tracking-wider font-medium">
          <th class="px-6 py-4">Order ID</th>
          <th class="px-6 py-4">Customer</th>
          <th class="px-6 py-4">Date</th>
          <th class="px-6 py-4">Total</th>
          <th class="px-6 py-4">Status</th>
          <th class="px-6 py-4 text-right">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-stone-100">
        <% if (orders.length === 0) { %>
          <tr>
            <td colspan="6" class="px-6 py-8 text-center text-stone-500">
              No orders found.
            </td>
          </tr>
        <% } else { %>
          <% orders.forEach(order => { %>
            <tr class="hover:bg-stone-50 transition-colors">
              <td class="px-6 py-4 font-mono text-sm text-stone-600">
                <%= order.id.split('-')[0] %>...
              </td>
              <td class="px-6 py-4">
                <div class="text-sm font-medium text-stone-900"><%= order.customer_name %></div>
                <div class="text-xs text-stone-500 mt-0.5"><%= order.customer_email %></div>
              </td>
              <td class="px-6 py-4 text-sm text-stone-500">
                <%= new Date(order.created_at).toLocaleDateString() %>
              </td>
              <td class="px-6 py-4 text-sm text-stone-900 font-medium">
                $<%= parseFloat(order.total).toFixed(2) %>
              </td>
              <td class="px-6 py-4">
                <% 
                  const statusColors = {
                    'pending': 'bg-yellow-50 text-yellow-700 border-yellow-200',
                    'processing': 'bg-blue-50 text-blue-700 border-blue-200',
                    'shipped': 'bg-indigo-50 text-indigo-700 border-indigo-200',
                    'delivered': 'bg-emerald-50 text-emerald-700 border-emerald-200',
                    'cancelled': 'bg-red-50 text-red-700 border-red-200'
                  };
                  const colorClass = statusColors[order.status] || 'bg-stone-50 text-stone-700 border-stone-200';
                %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border <%= colorClass %>">
                  <span class="capitalize"><%= order.status %></span>
                </span>
              </td>
              <td class="px-6 py-4 text-right text-sm font-medium">
                <a href="/admin/orders/<%= order.id %>" class="text-indigo-600 hover:text-indigo-900 bg-indigo-50 p-2 rounded hover:bg-indigo-100 transition-colors inline-flex items-center gap-1">
                  View
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
    <div class="bg-white px-6 py-4 border-t border-stone-100 flex items-center justify-between">
      <div class="text-sm text-stone-500">
        Page <span class="font-medium text-stone-900"><%= page %></span> of <span class="font-medium text-stone-900"><%= totalPages %></span>
      </div>
      <div class="flex gap-2">
        <% if (page > 1) { %>
          <a href="?page=<%= page - 1 %>" class="px-3 py-1 border border-stone-200 rounded text-sm font-medium text-stone-600 hover:bg-stone-50 transition-colors">Previous</a>
        <% } %>
        <% if (page < totalPages) { %>
          <a href="?page=<%= page + 1 %>" class="px-3 py-1 border border-stone-200 rounded text-sm font-medium text-stone-600 hover:bg-stone-50 transition-colors">Next</a>
        <% } %>
      </div>
    </div>
  <% } %>
</div>
