<div class="mb-8 flex items-center gap-4">
  <a href="/admin/products" class="text-stone-400 hover:text-stone-800 transition-colors">
    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
    </svg>
  </a>
  <div>
    <h1 class="text-3xl font-serif text-stone-900 tracking-tight"><%= title %></h1>
    <p class="text-stone-500 mt-1">Fill in the details below to <%= product.id ? 'update the' : 'create a new' %> product.</p>
  </div>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-stone-100 overflow-hidden max-w-4xl">
  <form action="<%= action %>" method="POST" class="p-8 space-y-6">
    <!-- CSRF protection -->
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Name -->
      <div>
        <label for="name" class="block text-sm font-medium text-stone-700 mb-1">Product Name *</label>
        <input type="text" id="name" name="name" value="<%= product.name || '' %>" required
          class="w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-stone-900 focus:border-stone-900 outline-none transition-all">
      </div>

      <!-- Slug -->
      <div>
        <label for="slug" class="block text-sm font-medium text-stone-700 mb-1">Slug (URL) *</label>
        <input type="text" id="slug" name="slug" value="<%= product.slug || '' %>" required
          class="w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-stone-900 focus:border-stone-900 outline-none transition-all">
        <p class="text-xs text-stone-500 mt-1">e.g., woven-basket-large</p>
      </div>

      <!-- Price -->
      <div>
        <label for="price" class="block text-sm font-medium text-stone-700 mb-1">Price ($) *</label>
        <input type="number" id="price" name="price" value="<%= product.price || '' %>" step="0.01" min="0" required
          class="w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-stone-900 focus:border-stone-900 outline-none transition-all">
      </div>

      <!-- Stock -->
      <div>
        <label for="stock" class="block text-sm font-medium text-stone-700 mb-1">Stock Quantity *</label>
        <input type="number" id="stock" name="stock" value="<%= product.stock !== undefined ? product.stock : 0 %>" min="0" required
          class="w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-stone-900 focus:border-stone-900 outline-none transition-all">
      </div>

      <!-- Category -->
      <div>
        <label for="category_id" class="block text-sm font-medium text-stone-700 mb-1">Category</label>
        <select id="category_id" name="category_id" 
          class="w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-stone-900 focus:border-stone-900 outline-none transition-all bg-white">
          <option value="">Select a Category</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.id %>" <%= product.category_id === cat.id ? 'selected' : '' %>>
              <%= cat.name %>
            </option>
          <% }) %>
        </select>
      </div>

      <!-- Image URL -->
      <div>
        <label for="image_url" class="block text-sm font-medium text-stone-700 mb-1">Image URL</label>
        <input type="text" id="image_url" name="image_url" value="<%= product.image_url || '' %>"
          class="w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-stone-900 focus:border-stone-900 outline-none transition-all"
          placeholder="/images/example.jpg or https://example.com/image.jpg">
      </div>
    </div>

    <!-- Description -->
    <div>
      <label for="description" class="block text-sm font-medium text-stone-700 mb-1">Description</label>
      <textarea id="description" name="description" rows="4"
        class="w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-stone-900 focus:border-stone-900 outline-none transition-all"
      ><%= product.description || '' %></textarea>
    </div>

    <!-- Is Active -->
    <div class="flex items-center pt-2">
      <input type="checkbox" id="is_active" name="is_active" class="w-5 h-5 text-stone-900 border-stone-300 rounded focus:ring-stone-900"
        <%= (product.is_active || product.id === undefined) ? 'checked' : '' %>>
      <label for="is_active" class="ml-3 block text-sm font-medium text-stone-700">
        Active Product (Visible to customers)
      </label>
    </div>

    <!-- Submit Buttons -->
    <div class="pt-6 border-t border-stone-100 flex items-center justify-end gap-4">
      <a href="/admin/products" class="px-5 py-2.5 text-sm font-medium text-stone-600 hover:text-stone-900 transition-colors">
        Cancel
      </a>
      <button type="submit" class="px-6 py-2.5 bg-stone-900 text-white text-sm font-medium rounded-lg hover:bg-stone-800 transition-colors">
        <%= product.id ? 'Save Changes' : 'Create Product' %>
      </button>
    </div>

  </form>
</div>

<script>
  // Simple slug generator from name
  document.getElementById('name').addEventListener('input', function(e) {
    <% if (!product.id) { %> // Only auto-generate slug for new products
      const name = e.target.value;
      const slug = name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)+/g, '');
      document.getElementById('slug').value = slug;
    <% } %>
  });
</script>
