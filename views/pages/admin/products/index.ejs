<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8">
  <div>
    <h1 class="text-3xl font-serif text-stone-900 tracking-tight">Products</h1>
    <p class="text-stone-500 mt-1">Manage your store's inventory and product details.</p>
  </div>
  <a href="/admin/products/create" class="mt-4 md:mt-0 px-5 py-2.5 bg-stone-900 text-white rounded-lg hover:bg-stone-800 transition-colors font-medium flex items-center">
    <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
    </svg>
    Add New Product
  </a>
</div>

<div class="bg-white rounded-2xl shadow-sm border border-stone-100 overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-stone-50 border-b border-stone-100 text-stone-500 text-sm uppercase tracking-wider font-medium">
          <th class="px-6 py-4">Product</th>
          <th class="px-6 py-4">Category</th>
          <th class="px-6 py-4">Price</th>
          <th class="px-6 py-4">Stock</th>
          <th class="px-6 py-4">Status</th>
          <th class="px-6 py-4 text-right">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-stone-100">
        <% if (products.length === 0) { %>
          <tr>
            <td colspan="6" class="px-6 py-8 text-center text-stone-500">
              No products found. Add your first product to get started.
            </td>
          </tr>
        <% } else { %>
          <% products.forEach(p => { %>
            <tr class="hover:bg-stone-50 transition-colors">
              <td class="px-6 py-4">
                <div class="flex items-center">
                  <div class="h-10 w-10 flex-shrink-0 bg-stone-100 rounded-lg overflow-hidden border border-stone-200">
                    <% if (p.image_url) { %>
                      <img src="<%= p.image_url %>" alt="<%= p.name %>" class="h-full w-full object-cover">
                    <% } else { %>
                      <div class="h-full w-full flex items-center justify-center text-stone-400">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                      </div>
                    <% } %>
                  </div>
                  <div class="ml-4">
                    <div class="text-sm font-medium text-stone-900"><%= p.name %></div>
                    <div class="text-xs text-stone-500 mt-0.5"><%= p.slug %></div>
                  </div>
                </div>
              </td>
              <td class="px-6 py-4">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-stone-100 text-stone-800">
                  <%= p.category_name || 'Uncategorized' %>
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-stone-900 font-medium">
                $<%= parseFloat(p.price).toFixed(2) %>
              </td>
              <td class="px-6 py-4 text-sm text-stone-500">
                <%= p.stock %>
              </td>
              <td class="px-6 py-4">
                <% if (p.is_active) { %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700">
                    Active
                  </span>
                <% } else { %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-stone-100 text-stone-600">
                    Inactive
                  </span>
                <% } %>
              </td>
              <td class="px-6 py-4 text-right text-sm font-medium">
                <div class="flex justify-end gap-3">
                  <a href="/admin/products/<%= p.id %>/edit" class="text-indigo-600 hover:text-indigo-900 bg-indigo-50 p-1.5 rounded hover:bg-indigo-100 transition-colors" title="Edit">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                  </a>
                  <% if (p.is_active) { %>
                    <form action="/admin/products/<%= p.id %>/delete" method="POST" class="inline" onsubmit="return confirm('Are you sure you want to deactivate this product?');">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                      <button type="submit" class="text-red-600 hover:text-red-900 bg-red-50 p-1.5 rounded hover:bg-red-100 transition-colors" title="Deactivate">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                        </svg>
                      </button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
    <div class="bg-white px-6 py-4 border-t border-stone-100 flex items-center justify-between">
      <div class="text-sm text-stone-500">
        Page <span class="font-medium text-stone-900"><%= page %></span> of <span class="font-medium text-stone-900"><%= totalPages %></span>
      </div>
      <div class="flex gap-2">
        <% if (page > 1) { %>
          <a href="?page=<%= page - 1 %>" class="px-3 py-1 border border-stone-200 rounded text-sm font-medium text-stone-600 hover:bg-stone-50 transition-colors">Previous</a>
        <% } %>
        <% if (page < totalPages) { %>
          <a href="?page=<%= page + 1 %>" class="px-3 py-1 border border-stone-200 rounded text-sm font-medium text-stone-600 hover:bg-stone-50 transition-colors">Next</a>
        <% } %>
      </div>
    </div>
  <% } %>
</div>
