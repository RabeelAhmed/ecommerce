<%# views/pages/home.ejs — rendered inside layout.ejs via express-ejs-layouts %>

<!-- ═══════════════════════════════════════════════════
     HERO SECTION
════════════════════════════════════════════════════ -->
<section class="relative min-h-screen flex items-center bg-gradient-to-b from-brand-50 via-white to-white overflow-hidden" id="hero">

  <!-- Decorative blobs -->
  <div class="pointer-events-none absolute -top-32 -left-32 w-96 h-96 rounded-full bg-brand-100/60 blur-3xl"></div>
  <div class="pointer-events-none absolute top-1/2 -right-24 w-72 h-72 rounded-full bg-accent/10 blur-3xl"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center relative z-10">

    <!-- Eyebrow -->
    <p class="animate-fade-in inline-flex items-center gap-2 text-xs font-semibold tracking-[0.2em] uppercase text-brand-500 bg-brand-50 border border-brand-200 px-4 py-1.5 rounded-full mb-6">
      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4"/></svg>
      New Arrivals · Spring 2026
    </p>

    <!-- Heading -->
    <h1 class="animate-fade-up font-display text-5xl sm:text-6xl lg:text-7xl font-bold text-stone-900 leading-tight max-w-3xl mx-auto mb-6">
      Discover<br>
      <span class="text-brand-500 italic">Handcrafted</span> Treasures
    </h1>

    <!-- Subtext -->
    <p class="animate-fade-up-delay-1 text-stone-500 text-lg sm:text-xl max-w-xl mx-auto mb-10 leading-relaxed">
      Ethically sourced artisan goods from craftspeople around the globe — each piece woven with culture, care, and intention.
    </p>

    <!-- CTA -->
    <div class="animate-fade-up-delay-2 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/shop" class="btn-primary text-base px-8 py-4 shadow-lg shadow-brand-200" id="hero-cta-primary">
        Explore Collection
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
      <a href="/about" class="btn-outline text-base px-8 py-4" id="hero-cta-secondary">Our Story</a>
    </div>

    <!-- Decorative hand-drawn SVG line -->
    <div class="animate-fade-up-delay-3 mt-14 flex justify-center opacity-40">
      <svg width="320" height="40" viewBox="0 0 320 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path
          d="M4 30 C 30 10, 60 35, 90 22 C 120 9, 150 38, 180 20 C 210 2, 240 34, 270 18 C 290 8, 306 28, 316 20"
          stroke="#c96b2c" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
          fill="none"
          stroke-dasharray="4 6"
        />
        <!-- Arrow tip -->
        <path d="M308 14 L316 20 L308 26" stroke="#c96b2c" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 animate-bounce opacity-50">
    <svg class="w-5 h-5 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     FEATURED CATEGORIES
════════════════════════════════════════════════════ -->
<section class="py-20 bg-white" id="categories">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14">
      <p class="text-xs font-semibold tracking-[0.2em] uppercase text-brand-500 mb-2">Browse by Category</p>
      <h2 class="font-display text-4xl font-bold text-stone-900">Shop the Collection</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">

      <!-- Category 1: Textiles -->
      <a href="/shop?category=textiles" class="group flex flex-col items-center gap-5 p-8 rounded-3xl bg-brand-50 border border-brand-100 hover:bg-brand-100 hover:border-brand-200 transition-all duration-300 hover:shadow-lg" id="cat-textiles">
        <div class="w-20 h-20 rounded-full bg-white shadow-md flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
          <!-- Thread / Textile SVG icon -->
          <svg class="w-10 h-10 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v18M3 12h18M4.5 4.5l15 15M19.5 4.5l-15 15"/>
          </svg>
        </div>
        <div class="text-center">
          <h3 class="font-display text-xl font-semibold text-stone-800 group-hover:text-brand-600 transition-colors">Textiles</h3>
          <p class="text-sm text-stone-500 mt-1">Hand-woven rugs, throws & tapestries</p>
        </div>
      </a>

      <!-- Category 2: Ceramics -->
      <a href="/shop?category=ceramics" class="group flex flex-col items-center gap-5 p-8 rounded-3xl bg-accent/5 border border-accent/20 hover:bg-accent/10 hover:border-accent/30 transition-all duration-300 hover:shadow-lg" id="cat-ceramics">
        <div class="w-20 h-20 rounded-full bg-white shadow-md flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
          <!-- Ceramics pot SVG icon -->
          <svg class="w-10 h-10 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 3h6m0 0c.712 1.215.987 2.664.75 4.12C15.51 8.577 15 9.765 15 11c0 3.314-1.343 4-3 4s-3-.686-3-4c0-1.235-.51-2.423-.75-3.88A6.002 6.002 0 0115 3zM9 18h6a1 1 0 001-1v-2H8v2a1 1 0 001 1z"/>
          </svg>
        </div>
        <div class="text-center">
          <h3 class="font-display text-xl font-semibold text-stone-800 group-hover:text-accent transition-colors">Ceramics</h3>
          <p class="text-sm text-stone-500 mt-1">Fired clay vessels, bowls & décor</p>
        </div>
      </a>

      <!-- Category 3: Jewellery -->
      <a href="/shop?category=jewellery" class="group flex flex-col items-center gap-5 p-8 rounded-3xl bg-amber-50 border border-amber-100 hover:bg-amber-100 hover:border-amber-200 transition-all duration-300 hover:shadow-lg" id="cat-jewellery">
        <div class="w-20 h-20 rounded-full bg-white shadow-md flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
          <!-- Gem / jewellery SVG icon -->
          <svg class="w-10 h-10 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3L2 9l10 12L22 9 12 3z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M2 9h20"/>
          </svg>
        </div>
        <div class="text-center">
          <h3 class="font-display text-xl font-semibold text-stone-800 group-hover:text-amber-600 transition-colors">Jewellery</h3>
          <p class="text-sm text-stone-500 mt-1">Silver, beadwork & traditional adornments</p>
        </div>
      </a>

    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     NEW ARRIVALS GRID
════════════════════════════════════════════════════ -->
<section class="py-20 bg-brand-50/50" id="new-arrivals">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="flex flex-col sm:flex-row items-start sm:items-end justify-between mb-12 gap-4">
      <div>
        <p class="text-xs font-semibold tracking-[0.2em] uppercase text-brand-500 mb-2">Just In</p>
        <h2 class="font-display text-4xl font-bold text-stone-900">New Arrivals</h2>
      </div>
      <a href="/shop" class="text-sm font-semibold text-brand-600 hover:text-brand-700 flex items-center gap-1 transition-colors" id="view-all-arrivals">
        View all
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <% products.forEach(function(product) { %>
        <%- include('../partials/product-card', { product: product }) %>
      <% }); %>
    </div>

  </div>
</section>

<!-- ═══════════════════════════════════════════════════
     TRUST STRIP
════════════════════════════════════════════════════ -->
<section class="py-12 border-t border-b border-stone-100 bg-white" id="trust-strip">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center">

      <div class="flex flex-col items-center gap-2">
        <svg class="w-7 h-7 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
        </svg>
        <p class="text-sm font-semibold text-stone-800">Ethically Sourced</p>
        <p class="text-xs text-stone-400">Fair wages, fair trade</p>
      </div>

      <div class="flex flex-col items-center gap-2">
        <svg class="w-7 h-7 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M3 14h18M10 6l-4 4 4 4M14 6l4 4-4 4"/>
        </svg>
        <p class="text-sm font-semibold text-stone-800">Free Returns</p>
        <p class="text-xs text-stone-400">30-day hassle-free returns</p>
      </div>

      <div class="flex flex-col items-center gap-2">
        <svg class="w-7 h-7 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/>
        </svg>
        <p class="text-sm font-semibold text-stone-800">Worldwide Shipping</p>
        <p class="text-xs text-stone-400">Ships to 80+ countries</p>
      </div>

      <div class="flex flex-col items-center gap-2">
        <svg class="w-7 h-7 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
        </svg>
        <p class="text-sm font-semibold text-stone-800">Handmade with Love</p>
        <p class="text-xs text-stone-400">Every piece is unique</p>
      </div>

    </div>
  </div>
</section>
