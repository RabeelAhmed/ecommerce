<div class="px-4 py-16 sm:px-6 lg:px-8 <%= locals.user ? 'max-w-5xl mx-auto' : 'max-w-md mx-auto' %>">
  <% if (locals.user) { %>
    <!-- Logged in view -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Left Column: Profile -->
      <div class="md:col-span-1 space-y-6">
        <div class="bg-white rounded-2xl p-8 border border-stone-100 shadow-sm text-center">
          <div class="w-16 h-16 rounded-full bg-brand-100 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h1 class="text-2xl font-display font-bold text-stone-900 mb-2">Welcome Back!</h1>
          <p class="text-stone-500 mb-8">You are successfully logged in.</p>
          
          <button id="logout-btn" class="w-full btn-outline mb-4">
            Log Out
          </button>
          <a href="/shop" class="block w-full btn-primary">
            Continue Shopping
          </a>
        </div>
      </div>

      <!-- Right Column: Order History -->
      <div class="md:col-span-2">
        <h2 class="text-2xl font-display font-bold text-stone-900 mb-6">Order History</h2>
        
        <% if (locals.orders && locals.orders.length > 0) { %>
          <div class="space-y-4">
            <% locals.orders.forEach(order => { %>
              <div class="bg-white rounded-2xl p-6 border border-stone-100 shadow-sm flex flex-col sm:flex-row sm:items-center justify-between gap-4 transition-all hover:shadow-md">
                <div>
                  <div class="flex items-center gap-3 mb-1">
                    <span class="font-mono text-sm font-semibold text-stone-900">#<%= order.id.split('-')[0].toUpperCase() %></span>
                    <% 
                      const statusColors = {
                        'pending': 'bg-yellow-50 text-yellow-700 border-yellow-200',
                        'processing': 'bg-blue-50 text-blue-700 border-blue-200',
                        'shipped': 'bg-indigo-50 text-indigo-700 border-indigo-200',
                        'delivered': 'bg-emerald-50 text-emerald-700 border-emerald-200',
                        'cancelled': 'bg-red-50 text-red-700 border-red-200',
                        'confirmed': 'bg-yellow-50 text-yellow-700 border-yellow-200'
                      };
                      const colorClass = statusColors[order.status] || 'bg-stone-50 text-stone-700 border-stone-200';
                    %>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border <%= colorClass %> capitalize">
                      <%= order.status === 'confirmed' ? 'pending' : order.status %>
                    </span>
                  </div>
                  <p class="text-sm text-stone-500">
                    <%= new Date(order.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %> &bull; $<%= parseFloat(order.total).toFixed(2) %>
                  </p>
                </div>
                <div class="flex-shrink-0">
                  <a href="/order/<%= order.id %>/confirmation" class="px-5 py-2 bg-stone-900 text-white text-sm font-medium rounded-lg hover:bg-stone-800 transition-colors inline-block text-center w-full sm:w-auto">
                    Track Order
                  </a>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="bg-white rounded-2xl p-12 border border-stone-100 shadow-sm text-center">
            <svg class="w-16 h-16 text-stone-300 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            <h3 class="text-lg font-medium text-stone-900 mb-1">No Orders Yet</h3>
            <p class="text-stone-500 mb-6">Looks like you haven't made any purchases.</p>
            <a href="/shop" class="btn-primary">Start Shopping</a>
          </div>
        <% } %>
      </div>
    </div>

    <script>
      document.getElementById('logout-btn').addEventListener('click', async () => {
        try {
          const res = await fetch('/api/auth/logout', { method: 'POST' });
          if (res.ok) {
            window.location.href = '/';
          } else {
            if (typeof showToast === 'function') showToast('Logout failed. Please try again.', 'error');
            else alert('Logout failed.');
          }
        } catch (e) {
          console.error(e);
          if (typeof showToast === 'function') showToast('An error occurred during logout.', 'error');
          else alert('Error during logout.');
        }
      });
    </script>

  <% } else { %>
    <!-- Logged out view (Tabs for Login / Register) -->
    <div class="bg-white rounded-2xl overflow-hidden border border-stone-100 shadow-sm">
      <div class="flex border-b border-stone-100">
        <button class="w-1/2 py-4 font-medium text-brand-600 border-b-2 border-brand-600" id="tab-login">Login</button>
        <button class="w-1/2 py-4 font-medium text-stone-400 border-b-2 border-transparent hover:text-stone-600 transition-colors" id="tab-register">Register</button>
      </div>

      <div class="p-8">
        <!-- Login Form -->
        <form id="form-login" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-stone-700 mb-1">Email</label>
            <input type="email" name="email" required class="w-full px-4 py-2 border border-stone-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all">
          </div>
          <div>
            <label class="block text-sm font-medium text-stone-700 mb-1">Password</label>
            <input type="password" name="password" required class="w-full px-4 py-2 border border-stone-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all">
          </div>
          <div class="pt-2">
            <button type="submit" class="w-full btn-primary !py-3">Log In</button>
          </div>
        </form>

        <!-- Register Form -->
        <form id="form-register" class="space-y-4 hidden">
          <div>
            <label class="block text-sm font-medium text-stone-700 mb-1">Full Name</label>
            <input type="text" name="fullName" required class="w-full px-4 py-2 border border-stone-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all">
          </div>
          <div>
            <label class="block text-sm font-medium text-stone-700 mb-1">Email</label>
            <input type="email" name="email" required class="w-full px-4 py-2 border border-stone-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all">
          </div>
          <div>
            <label class="block text-sm font-medium text-stone-700 mb-1">Password</label>
            <input type="password" name="password" required minlength="8" class="w-full px-4 py-2 border border-stone-200 rounded-xl focus:ring-2 focus:ring-brand-500 focus:border-brand-500 outline-none transition-all">
            <p class="text-xs text-stone-500 mt-1">Min 8 chars, 1 uppercase, 1 lowercase, 1 number.</p>
          </div>
          <div class="pt-2">
            <button type="submit" class="w-full btn-primary !py-3">Create Account</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Error/Success Message Container -->
    <div id="auth-message" class="mt-4 text-center text-sm hidden p-3 rounded-lg"></div>

    <script>
      const tabLogin = document.getElementById('tab-login');
      const tabRegister = document.getElementById('tab-register');
      const formLogin = document.getElementById('form-login');
      const formRegister = document.getElementById('form-register');
      const msgBox = document.getElementById('auth-message');

      function showMessage(msg, isError = false) {
        msgBox.textContent = msg;
        msgBox.className = `mt-4 text-center text-sm p-3 rounded-lg ${isError ? 'bg-red-50 text-red-600 border border-red-100' : 'bg-emerald-50 text-emerald-600 border border-emerald-100'}`;
        msgBox.classList.remove('hidden');
      }

      tabLogin.addEventListener('click', () => {
        formLogin.classList.remove('hidden');
        formRegister.classList.add('hidden');
        tabLogin.className = "w-1/2 py-4 font-medium text-brand-600 border-b-2 border-brand-600";
        tabRegister.className = "w-1/2 py-4 font-medium text-stone-400 border-b-2 border-transparent hover:text-stone-600 transition-colors";
        msgBox.classList.add('hidden');
      });

      tabRegister.addEventListener('click', () => {
        formRegister.classList.remove('hidden');
        formLogin.classList.add('hidden');
        tabRegister.className = "w-1/2 py-4 font-medium text-brand-600 border-b-2 border-brand-600";
        tabLogin.className = "w-1/2 py-4 font-medium text-stone-400 border-b-2 border-transparent hover:text-stone-600 transition-colors";
        msgBox.classList.add('hidden');
      });

      formLogin.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(formLogin));
        
        try {
          const res = await fetch('/api/auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          const result = await res.json();
          if (res.ok) {
            showMessage('Login successful!', false);
            setTimeout(() => window.location.reload(), 500);
          } else {
            showMessage(result.error || result.errors?.[0]?.msg || 'Login failed', true);
          }
        } catch (err) {
          showMessage('An error occurred during login.', true);
        }
      });

      formRegister.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(formRegister));
        
        try {
          const res = await fetch('/api/auth/register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          const result = await res.json();
          if (res.ok) {
            showMessage('Registration successful! Logging in...', false);
            setTimeout(() => window.location.reload(), 1000);
          } else {
            showMessage(result.error || result.errors?.[0]?.msg || 'Registration failed', true);
          }
        } catch (err) {
          showMessage('An error occurred during registration.', true);
        }
      });
    </script>
  <% } %>
</div>
