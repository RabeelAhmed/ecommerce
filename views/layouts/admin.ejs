<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title><%= typeof title !== 'undefined' ? title + ' | NOMADICA Admin' : 'NOMADICA Admin' %></title>

  <!-- CSRF token for AJAX calls -->
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Tailwind compiled CSS -->
  <link rel="stylesheet" href="/output.css">
</head>
<body class="font-body text-stone-800 bg-stone-50 flex h-screen overflow-hidden antialiased">

  <!-- Sidebar -->
  <aside class="w-64 bg-stone-900 text-stone-300 flex flex-col hidden md:flex">
    <div class="h-16 flex items-center px-6 bg-stone-950 font-serif text-xl text-white tracking-widest">
      NOMADICA
      <span class="ml-2 text-xs font-sans text-stone-500 uppercase tracking-widest bg-stone-800 px-2 py-0.5 rounded">Admin</span>
    </div>
    
    <nav class="flex-1 px-4 py-6 space-y-2">
      <a href="/admin" class="flex items-center px-4 py-2.5 rounded-lg hover:bg-stone-800 hover:text-white transition-colors <%= typeof title !== 'undefined' && title.includes('Dashboard') ? 'bg-stone-800 text-white' : '' %>">
        <svg class="w-5 h-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
        Dashboard
      </a>
      
      <a href="/admin/products" class="flex items-center px-4 py-2.5 rounded-lg hover:bg-stone-800 hover:text-white transition-colors <%= typeof title !== 'undefined' && title.includes('Product') ? 'bg-stone-800 text-white' : '' %>">
        <svg class="w-5 h-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
        </svg>
        Products
      </a>

      <a href="/admin/orders" class="flex items-center px-4 py-2.5 rounded-lg hover:bg-stone-800 hover:text-white transition-colors <%= typeof title !== 'undefined' && title.includes('Order') ? 'bg-stone-800 text-white' : '' %>">
        <svg class="w-5 h-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
        </svg>
        Orders
      </a>
    </nav>

    <div class="p-4 border-t border-stone-800">
      <form id="admin-logout-form" action="/api/auth/logout" method="POST" class="w-full">
        <button type="submit" class="flex items-center w-full px-4 py-2.5 text-stone-400 hover:text-white hover:bg-stone-800 rounded-lg transition-colors">
          <svg class="w-5 h-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
          </svg>
          Logout
        </button>
      </form>
    </div>
  </aside>

  <!-- Main Content -->
  <div class="flex-1 flex flex-col overflow-hidden">
    <!-- Header (Mobile menu & User Profile placeholder) -->
    <header class="h-16 bg-white border-b border-stone-200 flex items-center justify-between px-6 lg:px-8">
      <div class="md:hidden text-lg font-serif tracking-widest">
        NOMADICA <span class="text-xs font-sans text-stone-500 uppercase">Admin</span>
      </div>
      <div class="hidden md:block text-sm text-stone-500">
        Welcome back, Admin
      </div>
      <div class="flex items-center gap-4">
        <a href="/" target="_blank" class="text-sm text-stone-500 hover:text-stone-900 flex items-center gap-1">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          View Store
        </a>
      </div>
    </header>

    <!-- Page Content -->
    <main class="flex-1 overflow-y-auto bg-stone-50 p-6 lg:p-8">
      <%- body %>
    </main>
  </div>

  <!-- Toast Container -->
  <div id="toast-container" class="fixed bottom-4 right-4 z-[60] flex flex-col gap-2 pointer-events-none"></div>

  <!-- Admin Scripts -->
  <script>
    function showToast(message, type = 'success') {
      const container = document.getElementById('toast-container');
      const toast = document.createElement('div');
      
      const bgColor = type === 'success' ? 'bg-stone-900 border-stone-800' : 'bg-red-600 border-red-700';
      const icon = type === 'success' 
        ? `<svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`
        : `<svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`;

      toast.className = `transform transition-all duration-300 translate-y-full opacity-0 flex items-center gap-3 px-4 py-3 rounded-xl shadow-2xl border text-white ${bgColor} pointer-events-auto`;
      toast.innerHTML = `
        ${icon}
        <span class="font-medium text-sm">${message}</span>
      `;
      
      container.appendChild(toast);

      requestAnimationFrame(() => {
        toast.classList.remove('translate-y-full', 'opacity-0');
      });

      setTimeout(() => {
        toast.classList.add('translate-y-full', 'opacity-0');
        setTimeout(() => toast.remove(), 300);
      }, 3000);
    }

    document.getElementById('admin-logout-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      try {
        const res = await fetch('/api/auth/logout', { method: 'POST' });
        if (res.ok) {
          window.location.href = '/account';
        } else {
          showToast('Logout failed. Please try again.', 'error');
        }
      } catch (err) {
        showToast('An error occurred during logout.', 'error');
      }
    });
  </script>
</body>
</html>
